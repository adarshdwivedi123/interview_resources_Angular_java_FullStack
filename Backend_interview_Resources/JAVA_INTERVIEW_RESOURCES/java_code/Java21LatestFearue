Recrod Example:
The Problem — Old DTO Was Ugly
java// BEFORE — Old DTO class (50+ lines for simple data)
public class UserDTO {
    private String name;
    private String email;
    private int age;

    // Constructor
    public UserDTO(String name, String email, int age) {
        this.name = name;
        this.email = email;
        this.age = age;
    }

    // Getters
    public String getName()  { return name; }
    public String getEmail() { return email; }
    public int getAge()      { return age; }

    // equals & hashCode
    @Override
    public boolean equals(Object o) { ... } // 10 lines

    @Override
    public int hashCode() { ... } // 5 lines

    // toString
    @Override
    public String toString() {
        return "UserDTO{name=" + name + ", email=" + email + "}";
    }
}
java// AFTER — Java 21 Record (1 line!)
record UserDTO(String name, String email, int age) {}

// That's it! Auto-generated:
// ✅ Constructor
// ✅ name(), email(), age() — getters
// ✅ equals() and hashCode()
// ✅ toString()
// ✅ Immutable by default  





